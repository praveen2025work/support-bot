<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS Reverse Proxy Configuration for Chatbot Platform
  =====================================================
  Place this file in the IIS site root (e.g. C:\inetpub\chatbot\web.config).

  Prerequisites:
    - IIS URL Rewrite Module 2.1
    - Application Request Routing (ARR) 3.0
    - ARR proxy enabled (IIS Manager → Server → ARR → Server Proxy Settings → Enable)
    - Application Pool set to "No Managed Code"

  This configuration reverse-proxies all traffic to the Next.js UI
  running on localhost:3001. No managed code pipeline is used.
-->
<configuration>
  <system.webServer>
    <!-- Disable managed code handlers — pure reverse proxy -->
    <handlers>
      <clear />
      <add name="StaticFile" path="*" verb="*"
           modules="StaticFileModule,DefaultDocumentModule,DirectoryListingModule"
           resourceType="Either" requireAccess="Read" />
    </handlers>

    <!-- URL Rewrite: proxy all requests to Node.js -->
    <rewrite>
      <rules>
        <rule name="ReverseProxy" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <!-- Skip if a physical file exists in the IIS site folder -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="http://localhost:3001/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- WebSocket support (needed for Next.js HMR in dev) -->
    <webSocket enabled="true" />

    <!-- Security headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-XSS-Protection" value="1; mode=block" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
