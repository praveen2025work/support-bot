{
  "queries": [
    {
      "id": "q1",
      "name": "monthly_revenue",
      "description": "Monthly revenue breakdown by product line and region",
      "estimatedDuration": 3200,
      "url": "https://confluence.example.com/wiki/finance/monthly-revenue-report",
      "source": "finance",
      "type": "api",
      "endpoint": "/finance/revenue/{region}",
      "filters": [
        {
          "key": "date_range",
          "binding": "body"
        },
        {
          "key": "region",
          "binding": "path"
        }
      ],
      "chartConfig": {
        "defaultType": "line",
        "labelKey": "month",
        "valueKeys": ["revenue", "target"],
        "showLegend": true
      },
      "columnConfig": {
        "labelColumns": ["month"],
        "valueColumns": ["revenue", "target"]
      },
      "drillDown": [
        {
          "sourceColumn": "region",
          "targetQuery": "daily_orders",
          "targetFilter": "region",
          "label": "View Orders by Region"
        },
        {
          "sourceColumn": "product",
          "targetQuery": "revenue_by_segment",
          "targetFilter": "segment",
          "label": "View Revenue by Segment"
        }
      ]
    },
    {
