{
  "name": "chatbot-engine",
  "version": "1.0.0",
  "private": true,
  "description": "Chatbot Engine — NLP pipeline, query execution, admin API",
  "scripts": {
    "dev": "tsx watch --ignore './data/**' --ignore './dist/**' --ignore './*.jsonl' src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "train": "tsx src/training/scripts/train.ts",
    "evaluate": "tsx src/training/scripts/evaluate.ts"
  },
  "dependencies": {
    "@nlpjs/core": "^4.26.1",
    "@nlpjs/lang-en": "^4.26.1",
    "@nlpjs/nlp": "^4.27.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "fuse.js": "^7.0.0",
    "ky": "^1.7.2",
    "lru-cache": "^11.0.0",
    "module-alias": "^2.3.4",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "_moduleAliases": {
    "@": "dist"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
