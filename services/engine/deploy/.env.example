# ============================================================================
# MITR AI Chatbot Engine — Environment Configuration
# ============================================================================
# Copy this file to .env and customize for each instance.
# For multi-instance NAS deployment, set DATA_DIR, CONFIG_DIR, TRAINING_DIR
# to the shared NAS mount path accessible by all engine instances.
# ============================================================================

# --- Instance Identity ---
# Unique ID for this engine instance (used in health checks, logs, tracing)
INSTANCE_ID=engine-server-a

# --- Network ---
ENGINE_PORT=4001
UI_ORIGIN=http://your-frontend-host:3001

# --- API Backend ---
API_BASE_URL=http://your-api-server:8080/api
API_TOKEN=

# --- Shared Data Paths (NAS/NFS Mount) ---
# All mutable data — logs, learning, audit, indexes, preferences, knowledge
# Point to NAS mount for multi-instance: \\NAS\chatbot\data or /mnt/nas/chatbot/data
DATA_DIR=/mnt/nas/chatbot/data

# Configuration files — groups, settings, users, filters
# Point to NAS mount for multi-instance: \\NAS\chatbot\config or /mnt/nas/chatbot/config
CONFIG_DIR=/mnt/nas/chatbot/config

# NLP training data — corpus.json and group corpora
# Point to NAS mount for multi-instance
TRAINING_DIR=/mnt/nas/chatbot/training

# Uploaded documents storage (defaults to DATA_DIR/knowledge)
# KNOWLEDGE_DIR=/mnt/nas/chatbot/knowledge

# OpenAPI docs directory (optional, defaults to <cwd>/docs)
# DOCS_DIR=/mnt/nas/chatbot/docs

# Mock API db.json path (only needed if using mock-api)
# DB_JSON_PATH=/mnt/nas/chatbot/mock-api/db.json

# --- Rate Limiting ---
RATE_LIMIT_CHAT=1500
RATE_LIMIT_ADMIN=200
MAX_CONCURRENT_REQUESTS=50

# --- Logging ---
LOG_LEVEL=info

# --- Security ---
# ENGINE_API_KEY=your-secret-key
# LOG_ENCRYPTION_KEY=your-encryption-key

# --- Teams Integration (optional) ---
# TEAMS_APP_ID=
# TEAMS_APP_PASSWORD=
