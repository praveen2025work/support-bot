{
  "name": "csv-xlsx-connector",
  "version": "1.0.0",
  "private": true,
  "description": "CSV/XLSX File Connector — standalone service for CSV and Excel file data connectivity",
  "scripts": {
    "dev": "tsx watch --ignore './data/**' --ignore './dist/**' src/server.ts",
    "build": "node esbuild.config.mjs",
    "build:typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "lint": "eslint src/ --ext .ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
