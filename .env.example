# ═══════════════════════════════════════════════════════
# Environment Variables Reference
# ═══════════════════════════════════════════════════════
# Copy this file to one of:
#   .env.mock  — local dev with sample data (npm run dev:mock)
#   .env.dev   — real APIs, real auth       (npm run dev)
#   .env.prod  — production deployment      (npm run start:prod)
#
# See Admin → Guides → Config Guide for detailed setup.
# ═══════════════════════════════════════════════════════

# ── Core ──
NODE_ENV=development                    # development | production

# ── Engine Service ──
# The Next.js app always proxies to the engine. The engine must be running.
ENGINE_URL=http://localhost:4001        # Defaults to http://localhost:4001 when not set
ENGINE_PORT=4001                        # Port the engine listens on (default: 4001)

# ── User Authentication ──
USER_INFO_URL=                          # AD/SSO userinfo endpoint. Empty = mock user fallback

# ── Data API ──
API_BASE_URL=http://localhost:8080/api  # Tenant API base URL. Mock API for local dev
API_TOKEN=                              # Bearer token for authenticating to tenant APIs

# ── Security ──
ENGINE_API_KEY=                         # Secures Engine admin API. Required in production
LOG_ENCRYPTION_KEY=                     # Optional. Enables AES-256-GCM encryption-at-rest for conversation logs. Leave empty to store logs in plaintext.

# ── File Queries ──
# FILE_BASE_DIR=                        # Base directory for CSV/XLSX file paths.
                                        # When set, query filePath values resolve against this dir.
                                        # Example: FILE_BASE_DIR=//server/shared/reports
                                        # When not set, paths resolve relative to the engine directory.

# ── SQL Connector Services (optional) ──
# Standalone microservices for database connectivity. Start only what you need.
MSSQL_CONNECTOR_URL=http://localhost:4002   # MSSQL Connector service URL (default port: 4002)
ORACLE_CONNECTOR_URL=http://localhost:4003  # Oracle Connector service URL (default port: 4003)
MSSQL_CONNECTOR_API_KEY=                    # API key for MSSQL Connector auth
ORACLE_CONNECTOR_API_KEY=                   # API key for Oracle Connector auth
SQL_CREDENTIAL_KEY=                         # Encryption key for storing DB credentials (required for connectors)

# ── CORS ──
UI_ORIGIN=http://localhost:3001         # Allowed CORS origin for Engine

# ── Teams Bot (optional) ──
# TEAMS_APP_ID=
# TEAMS_APP_PASSWORD=
