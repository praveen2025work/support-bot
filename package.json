{
  "name": "chatbot",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "mock-api": "node mock-api/server.js",
    "dev:full": "npm run mock-api & npm run dev",
    "dev:monolith": "npm run mock-api & npm run dev",
    "dev:3service": "concurrently -n mock,engine,ui -c yellow,blue,green \"npm run svc:mock-api\" \"npm run svc:engine\" \"npm run svc:ui\"",
    "svc:mock-api": "cd services/mock-api && npm start",
    "svc:engine": "cd services/engine && API_BASE_URL=http://localhost:8080/api npm run dev",
    "svc:ui": "ENGINE_URL=http://localhost:4000 next dev",
    "build:engine": "cd services/engine && npm run build",
    "start:demo": "concurrently -n mock,engine,ui \"npm run svc:mock-api\" \"cd services/engine && API_BASE_URL=http://localhost:8080/api npm start\" \"ENGINE_URL=http://localhost:4000 next start\"",
    "start:prod": "concurrently -n engine,ui \"cd services/engine && npm start\" \"ENGINE_URL=http://localhost:4000 next start\"",
    "train": "tsx src/training/scripts/train.ts",
    "evaluate": "tsx src/training/scripts/evaluate.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@nlpjs/core": "^4.26.1",
    "@nlpjs/lang-en": "^4.26.1",
    "@nlpjs/nlp": "^4.27.0",
    "fuse.js": "^7.1.0",
    "ky": "^1.14.3",
    "lru-cache": "^11.2.6",
    "next": "^14.2.35",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "json-server": "^0.17.4",
    "msw": "^2.12.10",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
