{
  "name": "chatbot",
  "version": "1.0.0",
  "description": "",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",

    "dev:mock": "dotenv -e .env.mock -- concurrently -n mock,engine,ui -c yellow,blue,green \"npm run svc:mock-api\" \"cd services/engine && npm run dev\" \"npx next dev\"",
    "dev:mock:3svc": "dotenv -e .env.mock -- concurrently -n mock,engine,ui -c yellow,blue,green \"npm run svc:mock-api\" \"cd services/engine && npm run dev\" \"npx next dev\"",
    "dev": "dotenv -e .env.dev -- concurrently -n engine,ui -c blue,green \"cd services/engine && npm run dev\" \"npx next dev\"",

    "start:demo": "dotenv -e .env.mock -- concurrently -n mock,engine,ui -c yellow,blue,green \"npm run svc:mock-api\" \"cd services/engine && npm start\" \"npx next start\"",
    "start:prod": "dotenv -e .env.prod -- concurrently -n engine,ui -c blue,green \"cd services/engine && npm start\" \"npx next start\"",

    "svc:mock-api": "cd services/mock-api && npm start",
    "svc:engine": "cd services/engine && npm run dev",
    "svc:ui": "npx next dev",
    "build:engine": "cd services/engine && npm run build",
    "train": "tsx src/training/scripts/train.ts",
    "evaluate": "tsx src/training/scripts/evaluate.ts",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@nlpjs/core": "^4.26.1",
    "@nlpjs/lang-en": "^4.26.1",
    "@nlpjs/nlp": "^4.27.0",
    "fuse.js": "^7.1.0",
    "ky": "^1.14.3",
    "lru-cache": "^11.2.6",
    "next": "^14.2.35",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "json-server": "^0.17.4",
    "msw": "^2.12.10",
    "prettier": "^3.5.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.{json,md,yml}": ["prettier --write"]
  }
}
